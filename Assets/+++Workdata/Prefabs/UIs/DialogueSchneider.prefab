  portraitVictoria: {fileID: 0}
  portraitNPC: {fileID: 0}
  dialogueLines:
  - "Victoria: Igitt, \xFCberall diese Spinnennetze!"
  - 'Schneider: Wie bitte!?'
  - "Victoria: \xC4hm, ich meinte..."
  - 'Schneider: Ach, alles gut, meine LIebe! Ich bin Schneider. Hallo erstmal! Wie
    kommts, dass uns hier endlich mal jemand besucht?'
  - "Victoria: Ich muss hoch zur Sternwarte, um diesen Stern wieder in den Himmel
    schicken zu k\xF6nnen!"
  - "Schneider: Oh, das scheint wohl nicht so oft zu passieren... Ich k\xF6nnte dir
    den Weg nach oben zeigen!"
  - 'Victoria: Oh ja bitte!'
  - 'Schneider: ....unter einer Bedingung.'
  - 'Victoria: ...'
  - "Schneider: Bringe mir doch bitte meine B\xFCrste, dass ich die ganzen st\xF6renden
    Weben hier entfernen kann. Du findest sie sicher schneller als ich ."
  dialogueIndex: 0
  playercontroller: {fileID: 0}
