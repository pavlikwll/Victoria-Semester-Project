    - target: {fileID: 1360577447537047066, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_text
      value: "Victoria: Da dr\xFCben ist das Observatorium! Lass uns schnell dorthin!"
      objectReference: {fileID: 0}
    - target: {fileID: 1360577447537047066, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_VerticalAlignment
      value: 512
      objectReference: {fileID: 0}
    - target: {fileID: 2506986318966597017, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 2594571466493276081, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_text
      value: 'Victoria: ICH bin deine letzte Hoffnung!? Ich bringe dich sofort zur
        Sternwarte! Vielleicht ist da jemand, der uns weiterhelfen kann!'
      objectReference: {fileID: 0}
    - target: {fileID: 2594571466493276081, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_VerticalAlignment
      value: 512
      objectReference: {fileID: 0}
    - target: {fileID: 3452952090337576119, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 3677607405932834348, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 4591802858602491346, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_Name
      value: DialogContainer
      objectReference: {fileID: 0}
    - target: {fileID: 4591802858602491346, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 4714952635699456031, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
      propertyPath: m_text
      value: "Victoria: Du bist vom Himmel gefallen?\nDu musst dringend dorthin zur\xFCck!
        Sag mir, wie schaffe ich das?"
      objectReference: {fileID: 0}
    - target: {fileID: 4714952635699456031, guid: d6a7205e229fb1e4d8b63c3f9aebda78, type: 3}
