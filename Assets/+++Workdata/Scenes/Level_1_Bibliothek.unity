      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 6355733986909353220, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: 'Schneider: Ach, alles gut, meine Liebe! Ich bin Schneider. Hallo erstmal!
        Wie kommts, dass uns hier endlich mal jemand besucht?'
      objectReference: {fileID: 0}
    - target: {fileID: 6355733986909353220, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: 'dialogueLines.Array.data[6]'
      value: 'Victoria: Ja, sehr gerne!'
      objectReference: {fileID: 0}
    - target: {fileID: 6355733986909353220, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: 'dialogueLines.Array.data[7]'
      value: 'Schneider: Unter einer Bedingung...'
      objectReference: {fileID: 0}
    - target: {fileID: 6355733986909353220, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: 'dialogueLines.Array.data[8]'
      value: "Schneider: ...bringe mir doch bitte meine B\xFCrste, damit ich die
        ganzen st\xF6renden Weben hier entfernen kann."
      objectReference: {fileID: 0}
    - target: {fileID: 6355733986909353220, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: 'dialogueLines.Array.data[9]'
      value: 'Schneider: Du findest sie sicher schneller als ich .'
      objectReference: {fileID: 0}
    - target: {fileID: 6888475887402750818, guid: 1649517657f509e40bcb8b033b3c6880, type: 3}
      propertyPath: m_Name
      value: DialogueSchneider
      objectReference: {fileID: 0}
