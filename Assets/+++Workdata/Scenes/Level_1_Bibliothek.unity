    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'speakerOrder.Array.data[8]'
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'speakerOrder.Array.data[9]'
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: "Victoria: Entschuldigung, ich bin Victoria.... mir ist dieser Stern
        hier ins Buch gefallen und ich m\xF6chte ihn gerne zur\xFCck in..."
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: 'Alfred: ...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[4]'
      value: "Alfred: Hier wird mehr aufbewahrt, als in B\xFCchern geschrieben steht..."
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[5]'
      value: "Victoria: \xC4hm, wei\xDFt du, wie ich zur Sternwarte komme?"
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[6]'
      value: 'Alfred: ...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[7]'
      value: 'Alfred: Oh, da war schon lange niemand mehr...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[8]'
      value: 'Victoria: Okay, trotzdem danke...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[9]'
      value: 'Alfred: ...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'speakerOrder.Array.data[10]'
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'speakerOrder.Array.data[11]'
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[10]'
      value: 'Alfred: Du siehst es, verstehst es aber noch nicht...'
      objectReference: {fileID: 0}
    - target: {fileID: 7511523700264665969, guid: 202335141e067de428efe9ca9a35a47e, type: 3}
      propertyPath: 'dialogueLines.Array.data[11]'
      value: "Victoria: Ist das etwa eine Art R\xE4tsel?"
      objectReference: {fileID: 0}
